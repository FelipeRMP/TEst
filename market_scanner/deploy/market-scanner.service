[Unit]
Description=Market Scanner Worker
After=network.target

[Service]
Type=simple
User=scanner
WorkingDirectory=/home/scanner/TEst/market_scanner
Environment=SCAN_INTERVAL_SECONDS=60
Environment=SCAN_LIMIT=300
Environment=MIN_LIQUIDITY=0
Environment=MIN_EV=0.01
Environment=BANKROLL_AMOUNT=1000
ExecStart=/home/scanner/TEst/market_scanner/.venv/bin/python backend/workers/scan_worker.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
